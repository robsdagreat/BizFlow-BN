{
    "info": {
        "_postman_id": "b3e04e13-bc53-469b-9ba7-b73369a4c529",
        "name": "BizFlow Seller Flow",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.access_token) {",
                                    "    pm.collectionVariables.set(\"accessToken\", jsonData.access_token);",
                                    "    console.log(\"Access Token set: \" + jsonData.access_token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"seller1@example.com\",\n    \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Register (Optional)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"seller2@example.com\",\n    \"password\": \"password123\",\n    \"fullName\": \"New Seller\",\n    \"phone\": \"0987654321\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Seller Flow",
            "item": [
                {
                    "name": "Create Business",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.id) {",
                                    "    pm.collectionVariables.set(\"businessId\", jsonData.id);",
                                    "    console.log(\"Business ID set: \" + jsonData.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Postman Business\",\n    \"description\": \"Created via Postman\",\n    \"category\": \"Tech\",\n    \"city\": \"San Francisco\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/businesses",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "businesses"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Add Product",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Postman Product\",\n    \"price\": 100,\n    \"businessId\": \"{{businessId}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/products",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "products"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get My Business",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/businesses/my-business",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "businesses",
                                "my-business"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update Business",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"description\": \"Updated description via Postman\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/businesses/{{businessId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "businesses",
                                "{{businessId}}"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Discovery",
            "item": [
                {
                    "name": "Get Discovery (Filtered)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/discovery?city=San Francisco",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "discovery"
                            ],
                            "query": [
                                {
                                    "key": "city",
                                    "value": "San Francisco"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "accessToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "businessId",
            "value": "",
            "type": "string"
        }
    ]
}